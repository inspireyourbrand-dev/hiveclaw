# ============================================================
#  HiveClaw Environment Configuration
#  Copy to .env and fill in your values
# ============================================================

# --- OpenClaw Gateway ---
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_GATEWAY_HOST=127.0.0.1

# --- HiveControl Dashboard ---
HIVECONTROL_ENABLED=true
HIVECONTROL_PATH=/__hiveclaw__/hivecontrol/
HIVECONTROL_THEME=dark

# --- HiveMem (Built-in Memory Server) ---
HIVEMEM_ENABLED=true
HIVEMEM_PORT=8090
HIVEMEM_STORAGE=sqlite
# For SQLite (default, zero-config):
HIVEMEM_SQLITE_PATH=./data/hivemem.db
# For external mem9/TiDB (optional upgrade):
# HIVEMEM_STORAGE=tidb
# HIVEMEM_DSN=mysql://user:pass@gateway01.region.prod.clustername.tidbcloud.com:4000/mem9

# --- HiveMem Embeddings ---
# Built-in uses local embeddings. For higher quality, set an API key:
# HIVEMEM_EMBED_PROVIDER=openai
# HIVEMEM_EMBED_API_KEY=sk-...
# HIVEMEM_EMBED_MODEL=text-embedding-3-small

# --- HiveWorkflow ---
HIVEWORKFLOW_ENABLED=true
HIVEWORKFLOW_MAX_CONCURRENT=5

# --- Governor Mode (API Budget Protection) ---
GOVERNOR_ENABLED=true
GOVERNOR_MAX_CONCURRENT=1
GOVERNOR_MIN_DELAY_MS=2000
GOVERNOR_BACKOFF_TIERS=60000,900000,offline

# --- Agent Configuration ---
DEFAULT_ORCHESTRATOR=orion
AGENT_SPAWN_HARDWARE_CHECK=true
AGENT_SPAWN_MIN_FREE_RAM_MB=512
AGENT_SPAWN_MIN_FREE_CPU_PCT=20

# --- LLM Provider (for agent operations) ---
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o

# --- Docker-specific ---
# DOCKER_DATA_DIR=./docker-data
